# Product Catalog - Production Environment

# ============================================
# Application Settings
# ============================================
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# ============================================
# Database
# ============================================
USE_IN_MEMORY_DB=false
# DATABASE_CONNECTION_STRING=<set-in-secrets>

# ============================================
# Logging
# ============================================
LOG_LEVEL=Warning

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=https://product-catalog.example.com

# ============================================
# Angular Client
# ============================================
API_URL=https://api.product-catalog.example.com
