# Product Catalog - Staging Environment

# ============================================
# Application Settings
# ============================================
ASPNETCORE_ENVIRONMENT=Staging
ASPNETCORE_URLS=http://+:80

# ============================================
# Database
# ============================================
USE_IN_MEMORY_DB=false
# DATABASE_CONNECTION_STRING=<set-in-secrets>

# ============================================
# Logging
# ============================================
LOG_LEVEL=Information

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=https://staging.product-catalog.example.com

# ============================================
# Angular Client
# ============================================
API_URL=https://staging-api.product-catalog.example.com
